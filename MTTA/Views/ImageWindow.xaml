<Window x:Class="MTTA.Views.ImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MTTA.Views"
        mc:Ignorable="d"
        Title="ImageWindow" Height="450" Width="800"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged">
    <Grid>
        <!-- ScrollViewer to allow scrolling if image is larger than window -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                      VerticalScrollBarVisibility="Auto" 
                      CanContentScroll="True">
            <!-- Image control to display the original image size -->
            <Image x:Name="ImageViewer" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>
        </ScrollViewer>
    </Grid>
</Window>